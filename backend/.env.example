# Пример переменных окружения для продакшена.
# Скопируйте в .env и подставьте свои значения, затем экспортируйте перед запуском.

# Секретный ключ Django (обязательно сменить!)
SECRET_KEY=замените-на-длинную-случайную-строку

# Выключить отладку в проде
DEBUG=false

# Разрешённые хосты через запятую
ALLOWED_HOSTS=example.com,www.example.com

# PostgreSQL (если не задано — используется SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/messenger

# Redis для общего channel layer при нескольких процессах (если не задано — in-memory)
# REDIS_URL=redis://localhost:6379/0
